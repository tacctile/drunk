# Push Notifications (VAPID)
# Generate keys: npx web-push generate-vapid-keys
# Then add them here and to your Vercel environment variables
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_MAILTO=mailto:your@email.com

# Super Admin — hardcoded voter_id of the permanent super admin
# This voter gets full destructive admin access via the existing long-press nav mechanic
# Never store this in client-accessible code in production beyond NEXT_PUBLIC_
NEXT_PUBLIC_SUPER_ADMIN_ID=your_voter_id_here
